NEXT_PUBLIC_API_URL=http://localhost:8080

# API authentication — sent as X-API-Key header on every API request.
# Required when the API has API_KEY set (e.g. GKE deployment with api-auth-secret).
# NEXT_PUBLIC_API_KEY=your-api-key

# Webhook Testing tab — auto-populate gateway URL and API key
# NEXT_PUBLIC_WEBHOOK_GATEWAY_URL=https://memdog-webhook-gw-dev-xxx.uc.gateway.dev/webhook
# NEXT_PUBLIC_WEBHOOK_API_KEY=your-gcp-api-key

# Server-side API URL for Next.js rewrites (used when NEXT_PUBLIC_API_URL is empty
# to proxy /api/v1/* through the Next.js server, avoiding mixed-content issues).
# API_URL=http://34.x.x.x/gke-api
