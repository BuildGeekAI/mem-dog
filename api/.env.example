# Example .env file for local development
GCP_PROJECT_ID=memdog-dev
RAW_BUCKET=memdog-raw-data
META_BUCKET=memdog-metadata
MEMORIES_BUCKET=memdog-memories
ENVIRONMENT=dev

# Redis store (optional; for ?redis=true on /api/v1/store)
# Local: redis://localhost:6379/0  |  Docker: redis://redis:6379/0
# REDIS_URL=redis://localhost:6379/0

# Supabase store (optional; for ?supabase=true on /api/v1/store)
# Create store_kv table first: run api/supabase/store_kv.sql in Supabase SQL Editor
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# When SUPABASE_URL points to GCP API Gateway, add:
# SUPABASE_API_GATEWAY_KEY=your-gcp-api-key

# Supabase storage backend (STORAGE_BACKEND=supabase)
# Hybrid: raw binary data stays in GCS (RAW_BUCKET above), all other structured
# data (meta, memories, viewpoints, users, prompts, skills, stats, channels,
# index, ai_config) moves to Supabase PostgreSQL, and vector embeddings go into
# a dedicated pgvector table (mem_dog_embeddings).
#
# Prerequisites:
#   1. Apply SQL migrations in Supabase SQL Editor (or run locally against your Supabase DB):
#        api/supabase/mem_dog_blobs.sql
#        api/supabase/mem_dog_embeddings.sql
#   2. Set SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY (same as store, above)
#   3. Set STORAGE_BACKEND=supabase (and keep RAW_BUCKET set for GCS raw data)
#
# STORAGE_BACKEND=supabase

# System default AI (API): Gemini key for users in "system" key mode.
# SYSTEM_GEMINI_API_KEY=   # from https://aistudio.google.com/app/apikey

# Data processing pipeline AI (webhook agent + API). Primary: Gemini 3.0 Flash; fallback: Ollama Cloud.
# DATA_PIPELINE_AI_PRIMARY_MODEL=gemini/gemini-3-flash
# DATA_PIPELINE_AI_FALLBACK_MODEL=ollama_cloud/gemma3:4b
# DATA_PIPELINE_AI_FALLBACK_ENABLED=true
# OLLAMA_CLOUD_API_KEY=    # optional; from https://ollama.com/cloud (API + agent fallback)

# Webhook API Gateway (optional; auto-wired by deploy-api when webhook is deployed)
# When set, uploads with forward_to_webhook=true (e.g. from Testing tab) dispatch a data.uploaded event.
# WEBHOOK_GATEWAY_URL=https://memdog-webhook-gw-dev-xxx.uc.gateway.dev/webhook
# WEBHOOK_API_KEY=your-gcp-api-key
