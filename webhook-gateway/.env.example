# ---------------------------------------------------------------------------
# LLM Provider Configuration
# ---------------------------------------------------------------------------
# LLM_PROVIDER selects the backend.  Default: "gemini" (native google-genai SDK).
# Set to any litellm-supported provider for 20+ alternatives:
#   openai, anthropic, openrouter, mistral, together_ai, bedrock,
#   ollama, vllm, cloudflare, nvidia_nim, huggingface, litellm, etc.
# Full list: https://docs.openclaw.ai/providers
LLM_PROVIDER=gemini

# Model identifier.  For Gemini: bare model name (e.g. gemini-3.0-flash).
# For litellm providers: use provider/model format (e.g. openai/gpt-4o).
LLM_MODEL=

# Provider-specific API keys (set the one matching your LLM_PROVIDER):
GEMINI_API_KEY=your-gemini-api-key-here
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENROUTER_API_KEY=your-openrouter-api-key
# MISTRAL_API_KEY=your-mistral-api-key
# TOGETHERAI_API_KEY=your-together-api-key
# NVIDIA_API_KEY=your-nvidia-api-key

# Generic API key (used when provider-specific env var is not set):
# LLM_API_KEY=

# Base URL override (for self-hosted: Ollama, vLLM, LiteLLM proxy, etc.):
# LLM_API_BASE=http://localhost:11434

# Backward-compatible Gemini model name (used when LLM_MODEL is empty):
GEMINI_MODEL=gemini-3.0-flash

# Optional tuning:
# LLM_TEMPERATURE=0.1
# LLM_MAX_TOKENS=512

# ---------------------------------------------------------------------------
# Existing mem-dog webhook API gateway
# ---------------------------------------------------------------------------
WEBHOOK_GATEWAY_URL=https://your-webhook-gateway-url/webhook
WEBHOOK_API_KEY=your-webhook-api-key-here

# ---------------------------------------------------------------------------
# mem-dog API service
# ---------------------------------------------------------------------------
MEM_DOG_API_URL=http://localhost:8080

# Publish every inbound message as a memory record (true/false).
# Works with or without an LLM configured.
PUBLISH_TO_MEMORY=true

# ---------------------------------------------------------------------------
# OTEL telemetry
# ---------------------------------------------------------------------------
OTEL_ENABLED=true
OTEL_SERVICE_NAME=webhook-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=

# ---------------------------------------------------------------------------
# Channel Policies
# ---------------------------------------------------------------------------
# JSON config to enable/disable channels and restrict senders.
# Can be inline JSON or a path to a file.
# WGW_CHANNEL_CONFIG={"whatsapp":{"enabled":true,"allowFrom":["+14087310242"]},"email":{"enabled":false}}
# WGW_CHANNEL_CONFIG_FILE=/app/channel-config.json

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# API key to protect all webhook/query endpoints. Leave empty for open mode.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
# WGW_API_KEY=

# Comma-separated allowed client IPs (empty = allow all)
# WGW_ALLOWED_IPS=

# Max requests per minute per IP (0 = no limit)
# WGW_RATE_LIMIT=60

# Comma-separated CORS origins (empty = allow all)
# WGW_CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001
PORT=8080
