# Copy to .env.recording (same folder) or repo-root .env.recording — both are gitignored.
#   cp testing/ui/recording/.env.recording.example testing/ui/recording/.env.recording
#
RECORDING_PROFILE=gcp
RECORDING_BASE_URL=https://mem-dog-ui-dev-xxxxx.run.app
RECORDING_API_URL=
RECORDING_GATEWAY_URL=http://34.x.x.x
RECORDING_EMAIL=demo-recorder@yourdomain.com
RECORDING_PASSWORD=replace-me
# Local UI uses DEFAULT_USER_ID below unless you sign in; seed/warm must match.
RECORDING_USER_ID=00000000-0000-0000-0000-000000000001
RECORDING_API_TOKEN=
# Optional — default is testing/ui/recording/recordings (repo-relative if you set a path).
# Do not use ./testing/ui/... without repo-root resolution; leave unset unless you need a custom dir.
# RECORDING_OUTPUT_DIR=testing/ui/recording/recordings

# If bundled Chromium crashes on macOS (SEGV / signal 11), use installed Google Chrome:
# RECORDING_BROWSER_CHANNEL=chrome

# Step-by-step debug logs (waits + next click). Default ON; set to 0 to disable.
# RECORDING_DEBUG=1

# Injected pointer for recordVideo (OS cursor is not captured). Set 0 to disable.
# RECORDING_CURSOR=0

# Pause between steps in every scene (default 1000 ms).
# RECORDING_PAUSE_MS=1000

# Max total length per scene — all scenes (default 4000 ms).
# RECORDING_SCENE_MS=4000
